# ===========================================
# SpacetimeDB 云数据库配置
# ===========================================
# 部署到云端时，请修改为您的云数据库信息
#
# 使用方法:
#   1. 修改下面的配置为您的云数据库信息
#   2. 运行 ./deploy.sh cloud 进行云端部署
# ===========================================

# 云数据库 WebSocket 地址
VITE_STDB_URI=wss://dizhuai.cc.cd

# 云数据库名称
VITE_STDB_MODULE=doudizhu-game
