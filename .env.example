# ===========================================
# SpacetimeDB 配置
# ===========================================

# 数据库连接地址
# 本地开发: ws://localhost:3000
# 云数据库: wss://<your-database-id>.spacetimedb.io
VITE_STDB_URI=ws://localhost:3000

# 数据库名称
# 本地开发: doudizhu-game-v2
# 云数据库: 使用您在 SpacetimeDB Cloud 创建的数据库名称
VITE_STDB_MODULE=doudizhu-game-v2

# ===========================================
# 云数据库配置示例
# ===========================================
# 取消下面的注释并填入您的云数据库信息
# VITE_STDB_URI=wss://maincloud.spacetimedb.io
# VITE_STDB_MODULE=your-cloud-database-name

# ===========================================
# DouZero AI API 配置
# ===========================================
# DouZero API 服务地址
VITE_DOUZERO_API_URL=http://39.102.75.103/dizhuai

# DouZero 调试模式 (true/false)
VITE_DOUZERO_DEBUG=false
